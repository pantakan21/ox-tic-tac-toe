# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ===== Auth =====
JWT_SECRET=                # random string 32+ chars: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=               # random string 32+ chars (คนละตัวกับ JWT_SECRET)

# ===== AI Coach (server-side ONLY — ห้าม expose ให้ client) =====
GROQ_API_KEY=gsk_your-groq-api-key

# ===== Database (Docker ตั้งให้อัตโนมัติ — ไม่ต้องแก้ถ้าใช้ Docker) =====
DATABASE_URL=mysql://ox_user:ox_password@localhost:3306/ox_game

# ===== Redis (Docker ตั้งให้อัตโนมัติ — ไม่ต้องแก้ถ้าใช้ Docker) =====
REDIS_URL=redis://localhost:6379

# ===== Backend =====
PORT=3001
FRONTEND_URL=http://localhost:3000

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:3001
